{
  "name": "atom-flow",
  "version": "0.1.0",
  "description": "Workflow-automation-first agent harness with brainstorming gate and commit gate.",
  "skills": ["./skills/", "./shared-skills/"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-report-sync.sh"
          }
        ]
      }
    ]
  }
}
